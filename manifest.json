const KS='rs_sessions',KD='rs_start';
function getSessions(){return JSON.parse(localStorage.getItem(KS)||'[]');}
function saveSessions(s){localStorage.setItem(KS,JSON.stringify(s));}
function getStartDate(){let d=localStorage.getItem(KD);if(!d){d=new Date().toISOString().split('T')[0];localStorage.setItem(KD,d);}return new Date(d+'T00:00:00');}
function getCurrentWeek(){const s=getStartDate(),n=new Date(),d=Math.floor((n-s)/(86400000));return Math.min(Math.floor(d/7)+1,24);}
function getPhase(w){return PHASES.find(p=>p.weeks.includes(w))||PHASES[PHASES.length-1];}
function getStreak(){const s=getSessions();if(!s.length)return 0;const dates=[...new Set(s.map(x=>x.date))].sort().reverse();const today=new Date().toISOString().split('T')[0];const yest=new Date(Date.now()-86400000).toISOString().split('T')[0];if(dates[0]!==today&&dates[0]!==yest)return 0;let st=1;for(let i=1;i<dates.length;i++){const a=new Date(dates[i-1]+'T00:00:00'),b=new Date(dates[i]+'T00:00:00');if((a-b)===86400000)st++;else break;}return st;}
function getBestStreak(){const s=getSessions();if(!s.length)return 0;const dates=[...new Set(s.map(x=>x.date))].sort();let best=1,cur=1;for(let i=1;i<dates.length;i++){const a=new Date(dates[i-1]+'T00:00:00'),b=new Date(dates[i]+'T00:00:00');if((b-a)===86400000){cur++;best=Math.max(best,cur);}else cur=1;}return best;}
function buildSteps(phase){const steps=[];phase.warmup.forEach(ex=>steps.push({...ex,section:'warmup',sectionLabel:'Warm Up',round:0,id:steps.length}));for(let r=1;r<=phase.rounds;r++){const lbl=`Round ${r} of ${phase.rounds}`;phase.circuit.forEach((ex,i)=>{steps.push({...ex,section:'circuit',sectionLabel:lbl,round:r,id:steps.length});if(i<phase.circuit.length-1)steps.push({type:'rest',duration:phase.restEx,section:'circuit',sectionLabel:lbl,round:r,isRound:false,nextName:phase.circuit[i+1].name,id:steps.length});});if(r<phase.rounds)steps.push({type:'rest',duration:phase.restRound,section:'circuit',sectionLabel:`Round ${r} complete`,round:r,isRound:true,nextName:phase.circuit[0].name,id:steps.length});}phase.cooldown.forEach(ex=>steps.push({...ex,section:'cooldown',sectionLabel:'Cool Down',round:0,id:steps.length}));return steps;}
let actx=null;
function getCtx(){if(!actx)actx=new(window.AudioContext||window.webkitAudioContext)();return actx;}
function beep(f,d,v=0.2){try{const c=getCtx(),o=c.createOscillator(),g=c.createGain();o.connect(g);g.connect(c.destination);o.frequency.value=f;g.gain.setValueAtTime(v,c.currentTime);g.gain.exponentialRampToValueAtTime(0.001,c.currentTime+d);o.start();o.stop(c.currentTime+d);}catch(e){}}
function beepTick(){beep(440,.1);}function beepDone(){beep(880,.15);setTimeout(()=>beep(1100,.25),160);}
let wo=null,pendingSession=null;
function startWorkout(){const w=getCurrentWeek(),ph=getPhase(w),steps=buildSteps(ph);wo={steps,stepIndex:0,timer:0,interval:null,isPaused:false,startTime:Date.now(),phase:ph,week:w};showWo();}
function showWo(){document.getElementById('bnav').style.display='none';const sc=document.getElementById('screen');sc.style.paddingBottom='0';sc.style.overflow='hidden';renderWorkout();}
function quitWorkout(){if(wo&&wo.interval)clearInterval(wo.interval);wo=null;document.getElementById('bnav').style.display='flex';const sc=document.getElementById('screen');sc.style.paddingBottom='20px';sc.style.overflow='auto';navigate(currentView);}
function advanceStep(){if(!wo)return;if(wo.interval){clearInterval(wo.interval);wo.interval=null;}wo.stepIndex++;if(wo.stepIndex>=wo.steps.length){finishWorkout();return;}renderWorkout();initStep();}
function initStep(){if(!wo)return;const s=wo.steps[wo.stepIndex];if(s.type==='timed'||s.type==='rest'){wo.timer=s.duration;startTimer();}}
function startTimer(){if(!wo)return;if(wo.interval)clearInterval(wo.interval);wo.interval=setInterval(()=>{if(wo.isPaused)return;wo.timer--;if(wo.timer<=3&&wo.timer>0)beepTick();updateTimerDOM();if(wo.timer<=0){clearInterval(wo.interval);wo.interval=null;beepDone();setTimeout(advanceStep,600);}},1000);}
function togglePause(){if(!wo)return;wo.isPaused=!wo.isPaused;const btn=document.getElementById('pause-btn');if(btn)btn.textContent=wo.isPaused?'▶  Resume':'⏸  Pause';}
function updateTimerDOM(){if(!wo)return;const step=wo.steps[wo.stepIndex],total=step.duration;const secEl=document.getElementById('ring-sec'),fillEl=document.getElementById('ring-fill');if(secEl)secEl.textContent=wo.timer;if(fillEl){const c=440,p=Math.max(0,wo.timer/total);fillEl.setAttribute('stroke-dashoffset',(c*(1-p)).toFixed(2));}}
function finishWorkout(){const dur=Math.round((Date.now()-wo.startTime)/60000);pendingSession={phase:wo.phase.id,week:wo.week,duration:dur,date:new Date().toISOString().split('T')[0],rating:2};wo=null;document.getElementById('bnav').style.display='none';const sc=document.getElementById('screen');sc.style.paddingBottom='0';sc.style.overflow='auto';renderComplete();}
function saveSession(){if(!pendingSession)return;const sessions=getSessions();sessions.unshift(pendingSession);saveSessions(sessions);pendingSession=null;document.getElementById('bnav').style.display='flex';const sc=document.getElementById('screen');sc.style.paddingBottom='20px';navigate('home');}
let currentView='home',histMode='list',exFilter='all';
let calYear=new Date().getFullYear(),calMonth=new Date().getMonth();
function navigate(view){if(wo)return;currentView=view;['home','history','exercises','progress'].forEach(v=>{const el=document.getElementById('nb-'+v);if(el)el.classList.toggle('active',v===view);});if(view==='home')renderHome();else if(view==='history')renderHistory();else if(view==='exercises')renderExercises();else if(view==='progress')renderProgress();}
function renderHome(){const week=getCurrentWeek(),phase=getPhase(week),streak=getStreak();const wip=phase.weeks.indexOf(week)+1;const chips=phase.circuit.slice(0,4).map(e=>`<span class="ex-chip">${e.name}</span>`).join('');const dots=phase.weeks.map((_,i)=>{let c='wdot';if(i<wip-1)c+=' done';else if(i===wip-1)c+=' cur';return`<div class="${c}"></div>`;}).join('');document.getElementById('screen').innerHTML=`<div class="fade-in"><div class="home-hdr"><div><div class="app-title">Rugby<br>Strength</div><div class="app-sub">6-Month Home Programme</div></div><div class="streak-badge"><div class="streak-num">${streak}</div><div class="streak-lbl">Day streak</div></div></div><div class="sched-bar"><div class="sched-icon">📅</div><div class="sched-text"><strong>Mon–Thu</strong> morning &nbsp;·&nbsp; <strong>Fri</strong> rest &nbsp;·&nbsp; <strong>Sat</strong> rugby &nbsp;·&nbsp; <strong>Sun</strong> rest</div></div><div class="phase-bar"><div class="phase-tag">Phase ${phase.id} of 6</div><div class="phase-title">${phase.name}</div><div class="week-row"><span class="week-txt">Week ${wip} of 4</span><div class="week-dots">${dots}</div></div></div><div class="workout-card"><div class="wcard-hdr"><span class="wcard-lbl">Today's Workout</span><span class="dur-badge">${phase.duration}</span></div><div class="ex-chips">${chips}<span class="ex-chip">+more</span></div><button class="start-btn" onclick="startWorkout()">Start Workout</button></div></div>`;}
function renderWorkout(){if(!wo)return;const step=wo.steps[wo.stepIndex],total=wo.steps.length,idx=wo.stepIndex;const progress=((idx)/total*100).toFixed(1);const ill=getIllus(step.name);let illustHTML='';if(ill&&step.type!=='rest'){illustHTML=`<div class="wo-illus-row"><div class="wo-illus-box"><span class="illus-tag">Start</span>${ill.s}</div><div class="wo-illus-box"><span class="illus-tag">End</span>${ill.e}</div></div>`;}let mainHTML='';if(step.type==='rest'){mainHTML=`<div class="rest-title">${step.isRound?'ROUND COMPLETE':'REST'}</div><div class="next-up">Next: <strong>${step.nextName||'Cool Down'}</strong></div><div class="ring-wrap"><svg viewBox="0 0 165 165"><circle class="ring-track" cx="82" cy="82" r="70" transform="rotate(-90 82 82)"/><circle id="ring-fill" class="ring-fill" cx="82" cy="82" r="70" stroke-dasharray="440" stroke-dashoffset="0" transform="rotate(-90 82 82)"/></svg><div class="ring-txt"><span id="ring-sec" class="ring-sec">${wo.timer||step.duration}</span><span class="ring-lbl">sec</span></div></div>`;}else if(step.type==='timed'){mainHTML=`<div class="wo-name">${step.name}</div><div class="wo-desc">${step.desc}</div>${illustHTML}<div class="ring-wrap"><svg viewBox="0 0 165 165"><circle class="ring-track" cx="82" cy="82" r="70" transform="rotate(-90 82 82)"/><circle id="ring-fill" class="ring-fill" cx="82" cy="82" r="70" stroke-dasharray="440" stroke-dashoffset="0" transform="rotate(-90 82 82)"/></svg><div class="ring-txt"><span id="ring-sec" class="ring-sec">${step.duration}</span><span class="ring-lbl">sec</span></div></div>`;}else{mainHTML=`<div class="wo-name">${step.name}</div><div class="wo-desc">${step.desc}</div>${illustHTML}<div class="reps-circle"><div class="reps-num">${step.reps}</div><div class="reps-lbl">reps</div></div>`;}const isReps=step.type==='reps';document.getElementById('screen').innerHTML=`<div class="wo-screen"><div class="wo-topbar"><div class="wo-progress-track"><div class="wo-progress-fill" style="width:${progress}%"></div></div><button class="quit-btn" onclick="confirmQuit()"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div><div class="wo-label-row"><span class="wo-section">${step.sectionLabel}</span><span class="wo-counter">${idx+1}/${total}</span></div><div class="wo-main">${mainHTML}</div><div class="wo-ctrls">${isReps?`<button class="done-btn" onclick="advanceStep()">Done ✓</button>`:''}${!isReps?`<button id="pause-btn" class="pause-btn" onclick="togglePause()">${wo.isPaused?'▶  Resume':'⏸  Pause'}</button>`:''}<button class="skip-btn" onclick="advanceStep()">Skip →</button></div></div>`;if(!isReps&&wo.timer===0)initStep();else if(!isReps&&wo.timer>0){updateTimerDOM();if(!wo.interval)startTimer();}}
function confirmQuit(){if(confirm('Quit this workout? Progress will be lost.'))quitWorkout();}
function renderComplete(){if(!pendingSession)return;document.getElementById('screen').innerHTML=`<div class="complete-wrap fade-in"><div class="complete-icon"><svg viewBox="0 0 24 24" fill="none"><polyline points="20,6 9,17 4,12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg></div><div class="complete-title">Session<br>Done</div><div class="complete-sub">Phase ${pendingSession.phase} · Week ${pendingSession.week} · ${pendingSession.duration} min</div><div class="sec-lbl">How did it feel?</div><div class="rating-row">${[['😊','Easy',1],['💪','Solid',2],['🔥','Tough',3],['💀','Brutal',4]].map(([em,tx,v])=>`<button class="rbtn${pendingSession.rating===v?' sel':''}" onclick="setRating(${v})"><span class="rbtn-em">${em}</span><span class="rbtn-tx">${tx}</span></button>`).join('')}</div><div class="sec-lbl">Notes (optional)</div><textarea class="note-inp" id="ni" rows="3" placeholder="How did the session go?"></textarea><button class="save-btn" onclick="doSave()">Save Session</button></div>`;}
function setRating(v){if(!pendingSession)return;pendingSession.rating=v;document.querySelectorAll('.rbtn').forEach((b,i)=>b.classList.toggle('sel',i===v-1));}
function doSave(){if(!pendingSession)return;pendingSession.note=document.getElementById('ni')?.value?.trim()||'';saveSession();}
const EM=['😊','💪','🔥','💀'],RT=['Easy','Solid','Tough','Brutal'];
const DAYS=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
const MONTHS=['January','February','March','April','May','June','July','August','September','October','November','December'];
function fmtDate(d){return new Date(d+'T00:00:00').toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short'});}
function renderHistory(){const sessions=getSessions();document.getElementById('screen').innerHTML=`<div class="fade-in"><div class="page-hdr"><div class="page-title">History</div><div class="page-sub">${sessions.length} session${sessions.length!==1?'s':''} logged</div></div><div class="view-toggle"><button class="vt-btn${histMode==='list'?' active':''}" onclick="setHistMode('list')">List</button><button class="vt-btn${histMode==='cal'?' active':''}" onclick="setHistMode('cal')">Calendar</button></div>${histMode==='cal'?renderCalendar(sessions):renderSessList(sessions)}</div>`;}
function setHistMode(m){histMode=m;renderHistory();}
function renderSessList(sessions){if(!sessions.length)return`<div class="empty-st"><div class="empty-ic">🏉</div><div class="empty-tx">No sessions yet.<br>Complete your first workout to get started.</div></div>`;return`<div class="sess-list">${sessions.map(s=>{const ph=PHASES.find(p=>p.id===s.phase);return`<div class="sess-card"><div class="sess-em">${EM[(s.rating||2)-1]}</div><div class="sess-info"><div class="sess-date">${fmtDate(s.date)}</div><div class="sess-meta">Phase ${s.phase} ${ph?ph.name:''} · Week ${s.week} · ${s.duration||'?'} min · ${RT[(s.rating||2)-1]}</div>${s.note?`<div class="sess-note">${s.note}</div>`:''}</div></div>`;}).join('')}</div>`;}
function renderCalendar(sessions){const workoutDates=new Set(sessions.map(s=>s.date));const today=new Date().toISOString().split('T')[0];const firstDay=new Date(calYear,calMonth,1);const lastDay=new Date(calYear,calMonth+1,0);const startDow=firstDay.getDay();let cells='';for(let i=0;i<startDow;i++)cells+=`<div class="cal-day other-month"></div>`;for(let d=1;d<=lastDay.getDate();d++){const dStr=`${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;cells+=`<div class="cal-day${workoutDates.has(dStr)?' has-workout':dStr===today?' today':''}">${d}</div>`;}const hdrs=DAYS.map(d=>`<div class="cal-day-lbl">${d[0]}</div>`).join('');return`<div class="cal-wrap"><div class="cal-hdr"><button class="cal-nav" onclick="calPrev()">&#8249;</button><div class="cal-month">${MONTHS[calMonth]} ${calYear}</div><button class="cal-nav" onclick="calNext()">&#8250;</button></div><div class="cal-grid">${hdrs}${cells}</div></div>`;}
function calPrev(){calMonth--;if(calMonth<0){calMonth=11;calYear--;}renderHistory();}
function calNext(){calMonth++;if(calMonth>11){calMonth=0;calYear++;}renderHistory();}
function getAllExercises(){const seen=new Set(),result=[];PHASES.forEach(ph=>{['warmup','circuit','cooldown'].forEach(sec=>{ph[sec].forEach(ex=>{if(!seen.has(ex.name)){seen.add(ex.name);const inPhases=PHASES.filter(p=>['warmup','circuit','cooldown'].some(s=>p[s].some(e=>e.name===ex.name))).map(p=>p.id);const inSections=new Set();PHASES.forEach(p=>['warmup','circuit','cooldown'].forEach(s=>{if(p[s].some(e=>e.name===ex.name))inSections.add(s);}));result.push({...ex,phases:inPhases,sections:[...inSections]});}});});});return result;}
function renderExercises(){const all=getAllExercises();const filters=[{key:'all',label:'All'},{key:'warmup',label:'Warm Up'},{key:'circuit',label:'Circuit'},{key:'cooldown',label:'Cool Down'}];const filterHTML=filters.map(f=>`<button class="filter-btn${exFilter===f.key?' active':''}" onclick="setExFilter('${f.key}')">${f.label}</button>`).join('');let filtered=exFilter==='all'?all:all.filter(ex=>ex.sections.includes(exFilter));const cards=filtered.map(ex=>{const ill=getIllus(ex.name);const phTag=ex.phases.length===6?'All phases':`Phase${ex.phases.length>1?'s':''} ${ex.phases.join(', ')}`;const typeLabel=ex.sections.includes('circuit')?'Circuit':ex.sections.includes('warmup')?'Warm Up':'Cool Down';const illustHTML=ill?`<div class="ex-ref-illus"><div class="ex-ref-illus-box"><span class="ex-ref-tag">Start</span>${ill.s}</div><div class="ex-ref-illus-box"><span class="ex-ref-tag">End</span>${ill.e}</div></div>`:'';return`<div class="ex-ref-card"><div class="ex-ref-top"><div><div class="ex-ref-name">${ex.name}</div><div class="ex-ref-phase">${phTag}</div></div><div class="ex-ref-type">${typeLabel}</div></div><div class="ex-ref-desc">${ex.desc}</div>${illustHTML}</div>`;}).join('');document.getElementById('screen').innerHTML=`<div class="fade-in"><div class="page-hdr"><div class="page-title">Exercises</div><div class="page-sub">${filtered.length} exercises</div></div><div class="ex-ref-filters">${filterHTML}</div><div class="ex-ref-list">${cards}</div></div>`;}
function setExFilter(f){exFilter=f;renderExercises();}
function renderProgress(){const sessions=getSessions(),streak=getStreak(),best=getBestStreak(),week=getCurrentWeek();const total=sessions.length;const now=new Date(),sow=new Date(now);sow.setDate(now.getDate()-now.getDay());const thisWeek=sessions.filter(s=>new Date(s.date+'T00:00:00')>=sow).length;const phCards=PHASES.map(p=>{const cur=p.weeks.includes(week),done=week>p.weeks[p.weeks.length-1],unlocked=week>=p.weeks[0];let bc='badge-lock',bt='Locked';if(done){bc='badge-done';bt='✓ Done';}else if(cur){bc='badge-cur';bt='● Current';}return`<div class="ph-card${cur?' current':''}${!unlocked?' locked':''}"><div class="ph-card-hdr"><span class="ph-card-name">Phase ${p.id} — ${p.name}</span><span class="ph-badge ${bc}">${bt}</span></div><div class="ph-meta">Weeks ${p.weeks[0]}–${p.weeks[p.weeks.length-1]} · ${p.circuit.length} exercises · ${p.rounds} rounds · ${p.duration}</div></div>`;}).join('');document.getElementById('screen').innerHTML=`<div class="fade-in"><div class="page-hdr"><div class="page-title">Progress</div><div class="page-sub">Week ${week} of 24 · ${Math.round(week/24*100)}% complete</div></div><div class="stats-grid"><div class="stat-card"><div class="stat-num">${total}</div><div class="stat-lbl">Total Sessions</div></div><div class="stat-card"><div class="stat-num">${streak}</div><div class="stat-lbl">Day Streak</div></div><div class="stat-card"><div class="stat-num">${best}</div><div class="stat-lbl">Best Streak</div></div><div class="stat-card"><div class="stat-num">${thisWeek}</div><div class="stat-lbl">This Week</div></div></div><div class="sect-div">Programme Phases</div><div class="phases-list">${phCards}</div><div class="reset-wrap"><button class="reset-btn" onclick="resetProgramme()">&#8635;  Reset Programme & All Data</button></div></div>`;}
function resetProgramme(){if(!confirm('This will delete all sessions and reset your start date. Are you sure?'))return;localStorage.removeItem(KS);localStorage.removeItem(KD);getStartDate();navigate('home');}
navigate('home');
</script>
</body>
</html>
