<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Rugby Strength">
<link rel="manifest" href="/rugby-strength/manifest.json">
<meta name="theme-color" content="#080808">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<title>Rugby Strength</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{--bg:#080808;--surface:#101010;--card:#171717;--border:#252525;--accent:#B8FF57;--accent-dim:rgba(184,255,87,.12);--text:#EFEFEF;--muted:#5A5A5A;--muted2:#888;}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow:hidden;}
#app{height:100%;display:flex;flex-direction:column;max-width:480px;margin:0 auto;position:relative;}
.screen{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:20px;padding-top:0;}
.screen::-webkit-scrollbar{display:none;}
.bnav{position:fixed;top:0;left:50%;transform:translateX(-50%);width:100%;max-width:480px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;padding:env(safe-area-inset-top,10px) 0 10px;z-index:100;}
.nbtn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;background:none;border:none;color:var(--muted);font-family:'DM Sans',sans-serif;font-size:9px;font-weight:600;cursor:pointer;letter-spacing:.08em;text-transform:uppercase;padding:4px 0;}
.nbtn.active{color:var(--accent);}
.nbtn svg{width:20px;height:20px;stroke-width:1.8;}
.home-hdr{padding:88px 22px 16px;display:flex;justify-content:space-between;align-items:flex-start;}
.app-title{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:.05em;line-height:1;}
.app-sub{font-size:11px;color:var(--muted2);font-weight:500;margin-top:2px;}
.streak-badge{background:var(--accent-dim);border:1px solid rgba(184,255,87,.35);border-radius:14px;padding:10px 16px;text-align:center;}
.streak-num{font-family:'Bebas Neue',sans-serif;font-size:32px;color:var(--accent);line-height:1;}
.streak-lbl{font-size:9px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.12em;opacity:.8;}
.sched-bar{margin:0 22px 14px;background:var(--card);border-radius:14px;padding:14px 18px;border:1px solid var(--border);display:flex;align-items:center;gap:12px;}
.sched-icon{font-size:20px;}
.sched-text{font-size:12px;color:var(--muted2);line-height:1.5;}
.sched-text strong{color:var(--text);font-weight:600;}
.phase-bar{margin:0 22px 14px;background:var(--card);border-radius:18px;padding:18px 20px;border:1px solid var(--border);}
.phase-tag{font-size:9px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.14em;margin-bottom:5px;}
.phase-title{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:.03em;margin-bottom:12px;}
.week-row{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;}
.week-txt{font-size:11px;color:var(--muted2);}
.week-dots{display:flex;gap:6px;flex:1;margin-left:12px;}
.wdot{flex:1;height:4px;border-radius:2px;background:var(--border);}
.wdot.done{background:var(--accent);}
.wdot.cur{background:var(--accent);opacity:.45;}
.workout-card{margin:0 22px 16px;background:var(--card);border-radius:18px;padding:22px;border:1px solid var(--border);}
.wcard-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;}
.wcard-lbl{font-size:10px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.1em;}
.dur-badge{font-size:11px;font-weight:500;color:var(--muted2);background:var(--surface);padding:4px 10px;border-radius:20px;border:1px solid var(--border);}
.ex-chips{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:18px;}
.ex-chip{font-size:10px;font-weight:500;color:var(--muted2);background:var(--surface);padding:4px 10px;border-radius:20px;}
.start-btn{width:100%;background:var(--accent);color:#080808;border:none;border-radius:14px;padding:17px;font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.1em;cursor:pointer;transition:transform .12s,opacity .12s;}
.start-btn:active{transform:scale(.97);opacity:.88;}
.wo-screen{height:100%;display:flex;flex-direction:column;overflow:hidden;}
.wo-topbar{padding:20px 22px 0;display:flex;align-items:center;gap:14px;flex-shrink:0;}
.wo-progress-track{flex:1;height:3px;background:var(--border);border-radius:2px;overflow:hidden;}
.wo-progress-fill{height:100%;background:var(--accent);border-radius:2px;transition:width .4s ease;}
.quit-btn{background:none;border:none;color:var(--muted2);cursor:pointer;padding:4px;display:flex;}
.quit-btn svg{width:20px;height:20px;stroke-width:2;}
.wo-label-row{padding:10px 22px 0;display:flex;justify-content:space-between;align-items:center;flex-shrink:0;}
.wo-section{font-size:9px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.16em;}
.wo-counter{font-size:11px;color:var(--muted2);}
.wo-main{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:6px 24px 4px;min-height:0;overflow:hidden;}
.wo-name{font-family:'Bebas Neue',sans-serif;font-size:32px;text-align:center;line-height:1.05;letter-spacing:.02em;margin-bottom:3px;}
.wo-desc{font-size:11px;color:var(--muted2);text-align:center;max-width:270px;line-height:1.5;margin-bottom:8px;}
.wo-illus-row{display:flex;gap:14px;margin-bottom:8px;flex-shrink:0;align-items:flex-end;}
.wo-illus-box{display:flex;flex-direction:column;align-items:center;gap:3px;}
.wo-illus-box svg{width:72px;height:auto;opacity:.88;}
.illus-tag{font-size:8px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.1em;}
.ring-wrap{position:relative;width:140px;height:140px;margin-bottom:10px;flex-shrink:0;}
.ring-wrap svg{width:100%;height:100%;}
.ring-track{fill:none;stroke:var(--border);stroke-width:8;}
.ring-fill{fill:none;stroke:var(--accent);stroke-width:8;stroke-linecap:round;transition:stroke-dashoffset .9s linear;}
.ring-txt{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.ring-sec{font-family:'Bebas Neue',sans-serif;font-size:50px;color:var(--text);line-height:1;}
.ring-lbl{font-size:9px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.12em;}
.reps-circle{width:140px;height:140px;border-radius:50%;background:var(--card);border:8px solid var(--border);display:flex;flex-direction:column;align-items:center;justify-content:center;margin-bottom:10px;flex-shrink:0;}
.reps-num{font-family:'Bebas Neue',sans-serif;font-size:58px;color:var(--accent);line-height:1;}
.reps-lbl{font-size:10px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.1em;}
.rest-title{font-family:'Bebas Neue',sans-serif;font-size:15px;color:var(--muted2);letter-spacing:.22em;text-align:center;margin-bottom:4px;}
.next-up{font-size:12px;color:var(--muted2);text-align:center;margin-bottom:12px;}
.next-up strong{color:var(--text);font-weight:600;}
.wo-ctrls{padding:0 22px 22px;flex-shrink:0;}
.done-btn{width:100%;background:var(--accent);color:#080808;border:none;border-radius:14px;padding:15px;font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:.1em;cursor:pointer;transition:transform .12s;margin-bottom:10px;}
.done-btn:active{transform:scale(.97);}
.pause-btn{width:100%;background:var(--card);color:var(--text);border:1px solid var(--border);border-radius:14px;padding:12px;font-size:13px;font-weight:600;cursor:pointer;margin-bottom:8px;}
.skip-btn{width:100%;background:none;color:var(--muted2);border:none;padding:8px;font-size:12px;font-weight:500;cursor:pointer;}
.complete-wrap{padding:88px 22px 24px;}
.complete-icon{width:60px;height:60px;background:var(--accent-dim);border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:14px;border:1px solid rgba(184,255,87,.3);}
.complete-icon svg{width:28px;height:28px;stroke:var(--accent);stroke-width:2.5;}
.complete-title{font-family:'Bebas Neue',sans-serif;font-size:50px;letter-spacing:.03em;margin-bottom:4px;line-height:1;}
.complete-sub{font-size:13px;color:var(--muted2);margin-bottom:28px;}
.sec-lbl{font-size:10px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.12em;margin-bottom:10px;}
.rating-row{display:flex;gap:8px;margin-bottom:20px;}
.rbtn{flex:1;background:var(--card);border:2px solid var(--border);border-radius:12px;padding:11px 6px;cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:4px;transition:border-color .18s,background .18s;}
.rbtn.sel{border-color:var(--accent);background:var(--accent-dim);}
.rbtn-em{font-size:20px;}
.rbtn-tx{font-size:9px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.05em;}
.note-inp{width:100%;background:var(--card);border:1px solid var(--border);border-radius:12px;padding:13px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;resize:none;outline:none;transition:border-color .2s;margin-bottom:20px;}
.note-inp:focus{border-color:rgba(184,255,87,.5);}
.note-inp::placeholder{color:var(--muted);}
.save-btn{width:100%;background:var(--accent);color:#080808;border:none;border-radius:14px;padding:17px;font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.1em;cursor:pointer;transition:transform .12s;}
.save-btn:active{transform:scale(.97);}
.page-hdr{padding:88px 22px 16px;}
.page-title{font-family:'Bebas Neue',sans-serif;font-size:42px;letter-spacing:.04em;}
.page-sub{font-size:12px;color:var(--muted2);margin-top:3px;}
.view-toggle{display:flex;gap:8px;margin:0 22px 14px;}
.vt-btn{flex:1;padding:9px;border-radius:10px;border:1px solid var(--border);background:var(--card);color:var(--muted2);font-size:12px;font-weight:600;cursor:pointer;transition:all .18s;}
.vt-btn.active{background:var(--accent-dim);border-color:rgba(184,255,87,.4);color:var(--accent);}
.cal-wrap{padding:0 22px 20px;}
.cal-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;}
.cal-month{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.03em;}
.cal-nav{background:none;border:none;color:var(--muted2);font-size:20px;cursor:pointer;padding:4px 12px;line-height:1;}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;}
.cal-day-lbl{text-align:center;font-size:9px;font-weight:600;color:var(--muted2);text-transform:uppercase;padding:4px 0;}
.cal-day{aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:8px;font-size:12px;font-weight:500;color:var(--muted2);}
.cal-day.today{color:var(--text);font-weight:700;}
.cal-day.has-workout{background:var(--accent-dim);color:var(--accent);border:1px solid rgba(184,255,87,.35);font-weight:700;}
.cal-day.other-month{opacity:.25;}
.sess-list{padding:0 22px;display:flex;flex-direction:column;gap:10px;}
.sess-card{background:var(--card);border-radius:14px;padding:15px 17px;border:1px solid var(--border);display:flex;align-items:center;gap:14px;}
.sess-em{font-size:22px;width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:var(--surface);border-radius:10px;flex-shrink:0;}
.sess-info{flex:1;min-width:0;}
.sess-date{font-weight:600;font-size:13px;margin-bottom:2px;}
.sess-meta{font-size:11px;color:var(--muted2);}
.sess-note{font-size:11px;color:var(--muted2);font-style:italic;margin-top:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.empty-st{text-align:center;padding:60px 24px;color:var(--muted2);}
.empty-ic{font-size:48px;margin-bottom:12px;}
.empty-tx{font-size:14px;line-height:1.6;}
.ex-ref-filters{display:flex;gap:8px;padding:0 22px 16px;overflow-x:auto;-webkit-overflow-scrolling:touch;}
.ex-ref-filters::-webkit-scrollbar{display:none;}
.filter-btn{padding:7px 14px;border-radius:20px;border:1px solid var(--border);background:var(--card);color:var(--muted2);font-size:11px;font-weight:600;cursor:pointer;white-space:nowrap;transition:all .18s;flex-shrink:0;}
.filter-btn.active{background:var(--accent-dim);border-color:rgba(184,255,87,.4);color:var(--accent);}
.ex-ref-list{padding:0 22px;display:flex;flex-direction:column;gap:14px;margin-bottom:20px;}
.ex-ref-card{background:var(--card);border-radius:16px;padding:18px;border:1px solid var(--border);}
.ex-ref-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px;}
.ex-ref-name{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:.03em;line-height:1.1;}
.ex-ref-phase{font-size:9px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.1em;margin-top:2px;}
.ex-ref-type{font-size:9px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;background:var(--surface);padding:3px 8px;border-radius:8px;border:1px solid var(--border);}
.ex-ref-desc{font-size:12px;color:var(--muted2);line-height:1.55;margin-bottom:14px;}
.ex-ref-illus{display:flex;gap:20px;justify-content:center;align-items:flex-end;}
.ex-ref-illus-box{display:flex;flex-direction:column;align-items:center;gap:5px;}
.ex-ref-illus-box svg{width:95px;height:auto;}
.ex-ref-tag{font-size:9px;font-weight:600;color:var(--accent);text-transform:uppercase;letter-spacing:.1em;}
.stats-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;padding:0 22px 20px;}
.stat-card{background:var(--card);border-radius:14px;padding:16px;border:1px solid var(--border);}
.stat-num{font-family:'Bebas Neue',sans-serif;font-size:38px;color:var(--accent);line-height:1;margin-bottom:4px;}
.stat-lbl{font-size:10px;font-weight:600;color:var(--muted2);text-transform:uppercase;letter-spacing:.1em;}
.sect-div{padding:0 22px 10px;font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.14em;}
.phases-list{padding:0 22px;display:flex;flex-direction:column;gap:8px;margin-bottom:20px;}
.ph-card{background:var(--card);border-radius:14px;padding:16px 18px;border:1px solid var(--border);}
.ph-card.locked{opacity:.38;}
.ph-card.current{border-color:rgba(184,255,87,.5);}
.ph-card-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px;}
.ph-card-name{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:.03em;}
.ph-badge{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:.1em;padding:3px 9px;border-radius:20px;}
.badge-cur{background:var(--accent-dim);color:var(--accent);}
.badge-done{background:rgba(255,255,255,.05);color:var(--muted2);}
.badge-lock{background:rgba(255,255,255,.05);color:var(--muted2);}
.ph-meta{font-size:11px;color:var(--muted2);}
.reset-wrap{padding:0 22px 40px;}
.reset-btn{width:100%;background:none;border:1px solid var(--border);border-radius:12px;padding:13px;color:var(--muted2);font-size:13px;font-weight:500;cursor:pointer;}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px);}to{opacity:1;transform:translateY(0);}}
.fade-in{animation:fadeUp .25s ease forwards;}
</style>
</head>
<body>
<div id="app">
  <div id="screen" class="screen"></div>
  <nav class="bnav" id="bnav">
    <button class="nbtn active" id="nb-home" onclick="navigate('home')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>Home
    </button>
    <button class="nbtn" id="nb-history" onclick="navigate('history')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><polyline points="12,6 12,12 16,14"/></svg>History
    </button>
    <button class="nbtn" id="nb-exercises" onclick="navigate('exercises')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M18 3a3 3 0 00-3 3v12a3 3 0 003 3 3 3 0 003-3 3 3 0 00-3-3H6a3 3 0 00-3 3 3 3 0 003 3 3 3 0 003-3V6a3 3 0 00-3-3 3 3 0 00-3 3 3 3 0 003 3h12a3 3 0 003-3 3 3 0 00-3-3z"/></svg>Exercises
    </button>
    <button class="nbtn" id="nb-progress" onclick="navigate('progress')">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>Progress
    </button>
  </nav>
</div>
<script>
// ==================== SVG ILLUSTRATIONS ====================
const IL={
